{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "envName": { "value": "${AZURE_ENV_NAME}" },
    "location": { "value": "${AZURE_LOCATION}" },
    "enablePrivateLink": { "value": false },
    "modelName": { "value": "${AZURE_AI_FOUNDRY_MODEL_NAME=gpt-4o-mini}" },
    "modelVersion": { "value": "${AZURE_AI_FOUNDRY_MODEL_VERSION=2024-07-18}" },
    "modelDeploymentName": { "value": "${AZURE_AI_FOUNDRY_MODEL=gpt-4o-mini}" },
    "modelCapacity": { "value": "${AZURE_AI_FOUNDRY_MODEL_CAPACITY=30}" },
    "scenarioId": { "value": "${ACCELERATOR_SCENARIO_ID=sales-research}" }
  }
}
