{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "envName": { "value": "${AZURE_ENV_NAME}" },
    "location": { "value": "${AZURE_LOCATION}" },
    "enablePrivateLink": { "value": false },
    "externalIngress": { "value": true },
    "modelName": { "value": "${AZURE_AI_FOUNDRY_MODEL_NAME=gpt-5-mini}" },
    "modelVersion": { "value": "${AZURE_AI_FOUNDRY_MODEL_VERSION=2025-08-07}" },
    "modelDeploymentName": { "value": "${AZURE_AI_FOUNDRY_MODEL=gpt-5-mini}" },
    "modelCapacity": { "value": "${AZURE_AI_FOUNDRY_MODEL_CAPACITY=30}" },
    "extraModelDeploymentsJson": { "value": "${AZURE_AI_FOUNDRY_EXTRA_DEPLOYMENTS_JSON=[]}" },
    "scenarioId": { "value": "${ACCELERATOR_SCENARIO_ID=sales-research}" },
    "allowedOrigins": { "value": "${ALLOWED_ORIGINS=}" }
  }
}
