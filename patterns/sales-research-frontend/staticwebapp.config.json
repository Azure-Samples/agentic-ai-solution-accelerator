{
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/assets/*", "*.{css,js,svg,png,ico}"]
  },
  "routes": [
    {
      "route": "/api/*",
      "rewrite": "https://REPLACE-WITH-DEPLOYED-API-HOSTNAME/api/*"
    }
  ],
  "responseOverrides": {
    "404": { "rewrite": "/index.html" }
  },
  "globalHeaders": {
    "X-Content-Type-Options": "nosniff",
    "Referrer-Policy": "strict-origin-when-cross-origin"
  }
}
