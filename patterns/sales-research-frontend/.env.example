# Base URL the built UI calls at runtime.
#
# Local dev (npm run dev):
#   Leave this empty (or unset). The Vite dev server proxies /research
#   and /healthz to VITE_DEV_API_PROXY (default http://localhost:8000),
#   so the browser issues same-origin requests and CORS doesn't apply.
#
# Production / SWA build (npm run build):
#   Set this to the deployed Container App URL printed by `azd up`,
#   e.g. https://api-dev-xxx.azurecontainerapps.io
#   Make sure ALLOWED_ORIGINS on the API includes the SWA hostname:
#     azd env set ALLOWED_ORIGINS https://<your-swa>.azurestaticapps.net
#     azd provision
VITE_API_BASE_URL=

# Override the dev-server proxy target (rarely needed).
# Useful when pointing the local UI at a remote dev API instead of localhost.
# VITE_DEV_API_PROXY=http://localhost:8000
